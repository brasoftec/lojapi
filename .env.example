# Database
DATABASE_URL="postgresql://user:password@localhost:5432/store_api"
DATABASE_PROVIDER="postgresql"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"

# Server
PORT=3001
NODE_ENV=development

# Admin Master
ADMIN_MASTER_EMAIL="admin@sistema.com"
ADMIN_MASTER_PASSWORD="Admin@123"

# Upload
UPLOAD_DIR="uploads"
MAX_FILE_SIZE=5242880

# Rate Limit
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
